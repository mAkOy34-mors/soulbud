# ──────────────────────────────────────────────────
# SOULBUD.CO — Apache .htaccess
# ──────────────────────────────────────────────────

Options -Indexes
ServerSignature Off

# ── Security headers ───────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# ── Protect sensitive files ────────────────────────
<FilesMatch "\.(sql|env|log|md|json|lock|sh)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# ── Protect config / includes / vendor folders ─────
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/ - [F,L]
    RewriteRule ^includes/ - [F,L]
    RewriteRule ^vendor/ - [F,L]
</IfModule>

# ── Uploads: block PHP execution in uploads folder ─
# <Directory> is not allowed in .htaccess — use FilesMatch with RewriteCond instead
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_URI} ^/uploads/
    RewriteRule \.php$ - [F,L]
</IfModule>

# ── Gzip compression ──────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain
</IfModule>

# ── Browser caching ───────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/png  "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
</IfModule>
